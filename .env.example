# Optional DeepSeek API. The agent runs without this by default.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional Telegram push.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional generic webhook push. Payload: {"text": "...", "items": [...]}.
WEBHOOK_URL=

# Runtime
DATABASE_URL=sqlite:///data/feed_builder.sqlite3
TIMEZONE=Asia/Shanghai
USER_AGENT=StaticFeedBuilder/0.1 (+https://example.local)

# Optional ntfy mobile push. Use a random unguessable topic.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=

